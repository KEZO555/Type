<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Voice dictation (optional): download the offline model, then record for on-device STT. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Light, crisp key/cursor haptics. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Colour filter: writes the daltonizer keys. Granted once via adb:
         adb shell pm grant app.lightphonekeyboard android.permission.WRITE_SECURE_SETTINGS -->
    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <!-- Colour apps picker needs the full launchable-app list. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- Close apps on lock: kill background processes of recently used apps. -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <!-- Package visibility (Android 11+) for speech recognizer components. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LightKeyboard">

        <!-- The system keyboard (IME). Once enabled + selected, it appears in every text field. -->
        <service
            android:name=".LightImeService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Transparent shim: requests RECORD_AUDIO on the IME's behalf (an IME can't ask directly). -->
        <activity
            android:name=".MicPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Tiny launcher screen: a one-tap path to enable/select the keyboard. -->
        <activity
            android:name=".SetupActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Emoji picker: choose which emoji appear in the keyboard's emoji panel. -->
        <activity
            android:name=".EmojiSettingsActivity"
            android:exported="false"
            android:label="@string/setup_emoji"
            android:screenOrientation="portrait" />

        <!-- Languages: choose which languages the globe key cycles through. -->
        <activity
            android:name=".LanguagesActivity"
            android:exported="false"
            android:label="@string/setup_languages"
            android:screenOrientation="portrait" />

        <!-- My words: view / clear the vocabulary the keyboard has learned. -->
        <activity
            android:name=".VocabularyActivity"
            android:exported="false"
            android:label="@string/setup_vocab"
            android:screenOrientation="portrait" />

        <!-- Settings sections (opened from the SetupActivity menu). -->
        <activity
            android:name=".TypingSettingsActivity"
            android:exported="false"
            android:label="@string/section_typing"
            android:screenOrientation="portrait" />
        <activity
            android:name=".KeyboardSettingsActivity"
            android:exported="false"
            android:label="@string/section_keys"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ColorSettingsActivity"
            android:exported="false"
            android:label="@string/section_color"
            android:screenOrientation="portrait" />

        <!-- Colour apps: choose which apps pause the phone's grayscale while open. -->
        <activity
            android:name=".ColorAppsActivity"
            android:exported="false"
            android:label="@string/setup_color_apps"
            android:screenOrientation="portrait" />

        <!-- Colour filter service: watches the foreground app to pause/restore grayscale, handles
             the colour keymap keys, and (optionally) closes recent apps when the screen locks. -->
        <service
            android:name=".ColorFilterService"
            android:exported="false"
            android:label="@string/color_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/color_filter_service_config" />
        </service>
    </application>
</manifest>
